{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": [
    "src/main.ts",
    "src/three/**/*.ts",
    "src/game/data/**/*.ts",
    "src/game/state/**/*.ts",
    "src/game/systems/**/*.ts",
    "src/game/types.ts"
  ],
  "exclude": [
    "src/game/scenes/**/*.ts"
  ]
}
